# Git 忽略文件规则
# 适用于 GoAccess 多站点管理系统

# ================================================================================
# 操作系统文件
# ================================================================================

# Linux
.DS_Store
*~

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# ================================================================================
# 临时文件和缓存
# ================================================================================

# 临时文件
*.tmp
*.temp
*.swp
*.swo
*~
.#*

# 日志文件
*.log
logs/

# 备份文件
*.backup
*.bak
*.*~

# ================================================================================
# 编译产物（不适用于本项目，但作为通用规则保留）
# ================================================================================

# 目标文件
*.o
*.so
*.a
*.lib

# 编译输出
build/
dist/
*.pyc
__pycache__/

# ================================================================================
# 数据库文件（根据需要调整）
# ================================================================================

# GoAccess 数据库文件（如果在此目录）
*.db
*.log

# 但保留 .gitkeep 占位文件
!.gitkeep

# ================================================================================
# IDE 和编辑器配置
# ================================================================================

# VS Code
.vscode/
*.code-workspace

# JetBrains
.idea/
*.iml

# Vim
*.swo
*.swp

# Emacs
*~

# ================================================================================
# 其他
# ================================================================================

# 链接文件
*.lnk
