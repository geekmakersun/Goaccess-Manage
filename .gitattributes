# Git 属性配置
# 用于跨平台一致性

# ================================================================================
# 文本文件处理
# ================================================================================

# 所有 shell 脚本使用 LF 行尾符（Unix 风格）
*.sh text eol=lf

# 配置文件使用 LF 行尾符
*.conf text eol=lf
*.cnf text eol=lf

# Markdown 文档使用 LF 行尾符
*.md text eol=lf
*.txt text eol=lf

# JSON 文件使用 LF 行尾符
*.json text eol=lf

# YAML 文件使用 LF 行尾符
*.yml text eol=lf
*.yaml text eol=lf

# ================================================================================
# 二进制文件
# ================================================================================

# 图片文件
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.bmp binary

# 数据库文件
*.mmdb binary
*.db binary

# 压缩包
*.tar.gz binary
*.zip binary
*.bz2 binary

# GeoIP 数据库
GeoLite2-City.mmdb binary

# ================================================================================
# 差异合并策略
# ================================================================================

# 对于 JSON 文件，使用浅层合并
*.json merge=union

# 对于 Markdown 文件，使用浅层合并
*.md merge=union
